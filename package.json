{
  "name": "@tricksumo/ws-await",
  "version": "0.1.2",
  "description": "Promise-based request-response pattern for AWS API Gateway WebSockets, with auto-reconnect, heartbeat, and a React hook.",
  "license": "MIT",
  "author": "Rishi Tiwari",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "keywords": [
    "websocket",
    "aws",
    "aws-lambda",
    "api-gateway",
    "react",
    "async-await",
    "websocket-client",
    "serverless",
    "real-time"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tricksumo/ws-await"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "zustand": ">=5.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "zustand": "^5.0.0"
  }
}
